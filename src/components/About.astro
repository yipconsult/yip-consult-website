---
import site from '../data/site.json';
const { heading, english, cantonese } = site.about;
---

<section id="about" class="section-container">
  <!-- Section header -->
  <div class="mb-16">
    <span class="text-navy-light text-sm font-medium tracking-widest uppercase mb-4 block">About Us</span>
    <h2 class="section-heading mb-4">{heading}</h2>
    <p class="section-subheading text-gray-400">{english}</p>
  </div>

  <!-- Content grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

    <!-- LEFT: Work Style -->
    <div>
      <div class="card mb-6">
        <p class="text-gray-300 leading-relaxed mb-4">{cantonese.intro}</p>
        <p class="text-gray-400 leading-relaxed">{cantonese.mission}</p>
      </div>

      <h3 class="text-xl font-heading font-bold mb-5 tracking-snug">{cantonese.style.heading}</h3>
      <ul class="space-y-4">
        {cantonese.style.points.map(point => (
          <li class="flex items-start gap-3 text-sm text-gray-400 leading-relaxed">
            <span class="w-6 h-6 rounded-full bg-navy/20 text-navy-light flex items-center justify-center text-xs flex-shrink-0 mt-0.5 font-bold">
              ✓
            </span>
            {point}
          </li>
        ))}
      </ul>
    </div>

    <!-- RIGHT: Process + Tech -->
    <div>
      <h3 class="text-xl font-heading font-bold mb-5 tracking-snug">{cantonese.process.heading}</h3>
      <ol class="space-y-5 mb-10">
        {cantonese.process.steps.map((step, i) => (
          <li class="flex items-start gap-4">
            <span class="w-8 h-8 rounded-lg bg-navy text-white flex items-center justify-center text-sm font-bold flex-shrink-0">
              {i + 1}
            </span>
            <p class="text-sm text-gray-400 leading-relaxed pt-1">{step}</p>
          </li>
        ))}
      </ol>

      <div class="card">
        <p class="text-sm text-gray-400 leading-relaxed mb-4">{cantonese.tech}</p>
        <p class="text-sm text-white font-medium leading-relaxed">{cantonese.cta}</p>
      </div>
    </div>

  </div>
</section>
