---
import site from '../data/site.json';
const { heading, subheading, items } = site.projects;
---

<section id="projects" class="section-container relative">
  <!-- Section header -->
  <div class="mb-16">
    <span class="text-navy-light text-sm font-medium tracking-widest uppercase mb-4 block">Projects</span>
    <h2 class="section-heading mb-4">{heading}</h2>
    <p class="section-subheading">{subheading}</p>
  </div>

  <!-- Project grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {items.map(project => (
      <a
        href={project.status === 'live' ? project.url : `/projects/${project.slug}`}
        target={project.url && project.url.startsWith('http') ? '_blank' : '_self'}
        rel={project.url && project.url.startsWith('http') ? 'noopener noreferrer' : ''}
        class="card group flex flex-col"
      >
        <div class="flex items-start justify-between mb-4">
          <!-- Icon -->
          <div class="text-3xl">{project.icon}</div>

          <!-- Status badge -->
          {project.status === 'live' ? (
            <span class="flex items-center gap-1.5 text-xs text-green-400 bg-green-400/10 px-3 py-1 rounded-full">
              <span class="w-1.5 h-1.5 bg-green-400 rounded-full" />
              Live
            </span>
          ) : (
            <span class="flex items-center gap-1.5 text-xs text-amber-400 bg-amber-400/10 px-3 py-1 rounded-full">
              <span class="w-1.5 h-1.5 bg-amber-400 rounded-full" />
              In Development
            </span>
          )}
        </div>

        <!-- Name -->
        <h3 class="text-lg font-heading font-bold tracking-snug mb-2
                   group-hover:text-navy-light transition-colors duration-300">
          {project.name}
        </h3>

        <!-- Description -->
        <p class="text-sm text-gray-400 leading-relaxed mb-5 flex-1">
          {project.description}
        </p>

        <!-- Tech tags -->
        <div class="flex flex-wrap gap-2">
          {project.tech.map(t => (
            <span class="text-xs text-gray-500 bg-white/[0.04] px-2.5 py-1 rounded-md border border-white/[0.06]">
              {t}
            </span>
          ))}
        </div>

        <!-- Arrow indicator -->
        <div class="mt-4 text-gray-600 group-hover:text-navy-light transition-colors duration-300 flex items-center gap-1 text-sm">
          {project.status === 'live' ? (project.url && project.url.startsWith('http') ? 'Visit site' : 'View project') : 'Learn more'}
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </div>
      </a>
    ))}
  </div>
</section>
