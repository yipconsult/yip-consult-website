---
import site from '../data/site.json';
const { hero, site: siteMeta } = site;
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Subtle gradient orb -->
  <div class="absolute top-1/3 -right-64 w-[600px] h-[600px] bg-navy/10 rounded-full blur-[120px] pointer-events-none" />

  <div class="section-container w-full pt-24 md:pt-32">
    <div class="max-w-4xl">
      <!-- Tagline chip -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/[0.04] border border-white/[0.08] mb-8">
        <span class="w-2 h-2 bg-navy-light rounded-full animate-pulse" />
        <span class="text-sm text-gray-300">{siteMeta.tagline}</span>
      </div>

      <!-- Headline -->
      <h1 class="section-heading text-5xl md:text-6xl lg:text-7xl mb-6 leading-[1.05]">
        {hero.headline}
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl text-gray-400 max-w-2xl mb-10 leading-relaxed">
        {hero.subheadline}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={hero.cta.primary.href} class="btn-primary text-base !py-4 !px-8">
          {hero.cta.primary.label}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={hero.cta.secondary.href} class="btn-outline text-base !py-4 !px-8">
          {hero.cta.secondary.label}
        </a>
      </div>

      <!-- Trust badges row -->
      <div class="mt-16 flex flex-wrap items-center gap-6 text-sm text-gray-500">
        <span class="text-gray-600">Trusted by SMEs across</span>
        <span class="px-3 py-1 rounded-full bg-white/[0.03] border border-white/[0.06] text-gray-400">🇭🇰 Hong Kong</span>
        <span class="w-px h-4 bg-white/10 hidden sm:block" />
        <span class="hidden sm:inline text-gray-600">Modern stack:</span>
        <span class="hidden sm:inline text-gray-500">Next.js · OpenAI · Supabase · WhatsApp API</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-gray-600 animate-bounce">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
  </div>
</section>
