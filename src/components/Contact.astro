---
import site from '../data/site.json';
const { heading, subheading, whatsapp, email, formspree } = site.contact;
---

<section id="contact" class="section-container">
  <!-- Section header -->
  <div class="mb-16 text-center">
    <span class="text-navy-light text-sm font-medium tracking-widest uppercase mb-4 block">Contact</span>
    <h2 class="section-heading mb-4">{heading}</h2>
    <p class="section-subheading max-w-xl mx-auto">{subheading}</p>
  </div>

  <div class="max-w-3xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
    <!-- LEFT: WhatsApp -->
    <div class="card text-center flex flex-col justify-center">
      <div class="text-4xl mb-4">💬</div>
      <h3 class="text-xl font-heading font-bold mb-2">WhatsApp</h3>
      <p class="text-gray-400 text-sm mb-6">Fastest way to reach us. We reply within hours during business days.</p>
      <a
        href={whatsapp.href}
        class="btn-primary !px-8 !py-4 w-full justify-center"
      >
        {whatsapp.label}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      </a>
      <p class="text-gray-600 text-xs mt-4">
        Or email <a href={`mailto:${email}`} class="text-gray-400 hover:text-white underline underline-offset-4 transition-colors">{email}</a>
      </p>
    </div>

    <!-- RIGHT: Contact Form -->
    <div class="card">
      <h3 class="text-xl font-heading font-bold mb-6">Send a Message</h3>
      <form
        action={formspree.action}
        method="POST"
        class="space-y-4"
      >
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">{formspree.fields.name}</label>
          <input
            type="text"
            name="name"
            required
            class="w-full bg-black border border-white/[0.08] rounded-lg px-4 py-2.5 text-white text-sm
                   placeholder:text-gray-600 focus:outline-none focus:border-navy/50 focus:ring-1 focus:ring-navy/20
                   transition-colors"
            placeholder="你的稱呼"
          />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">{formspree.fields.email}</label>
          <input
            type="email"
            name="email"
            required
            class="w-full bg-black border border-white/[0.08] rounded-lg px-4 py-2.5 text-white text-sm
                   placeholder:text-gray-600 focus:outline-none focus:border-navy/50 focus:ring-1 focus:ring-navy/20
                   transition-colors"
            placeholder="you@company.com"
          />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">{formspree.fields.company}</label>
          <input
            type="text"
            name="company"
            class="w-full bg-black border border-white/[0.08] rounded-lg px-4 py-2.5 text-white text-sm
                   placeholder:text-gray-600 focus:outline-none focus:border-navy/50 focus:ring-1 focus:ring-navy/20
                   transition-colors"
            placeholder="公司名稱 (選填)"
          />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">{formspree.fields.message}</label>
          <textarea
            name="message"
            required
            rows="4"
            class="w-full bg-black border border-white/[0.08] rounded-lg px-4 py-2.5 text-white text-sm
                   placeholder:text-gray-600 focus:outline-none focus:border-navy/50 focus:ring-1 focus:ring-navy/20
                   transition-colors resize-none"
            placeholder="簡單講下你想做啲乜..."
          ></textarea>
        </div>
        <button type="submit" class="btn-primary !px-8 !py-3 w-full justify-center">
          {formspree.submit}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
          </svg>
        </button>
        <p class="text-xs text-gray-600 text-center">
          We'll get back to you within 1 business day.
        </p>
      </form>
    </div>
  </div>
</section>
