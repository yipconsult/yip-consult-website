---
import site from '../data/site.json';
const { copyright, tagline, links } = site.footer;
---

<footer class="border-t border-white/[0.06] bg-surface/50">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Left -->
      <div class="flex flex-col items-center md:items-start gap-1">
        <div class="flex items-center gap-2 mb-1">
          <img src="/logo-light.jpg" alt="YipConsult" class="h-7 w-auto" />
        </div>
        <p class="text-sm text-gray-500">{tagline}</p>
      </div>

      <!-- Center: Links -->
      <div class="flex items-center gap-6">
        {links.map(link => (
          <a
            href={link.href}
            class="text-sm text-gray-400 hover:text-white transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right -->
      <p class="text-xs text-gray-600">{copyright}</p>
    </div>
  </div>
</footer>
