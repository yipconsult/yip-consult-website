---
import site from '../data/site.json';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-black/80 backdrop-blur-md border-b border-white/[0.06]">
  <nav class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 flex items-center justify-between h-16 md:h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group" aria-label="YipConsult home">
      <img
        src="/YIP Logo.png"
        alt="YipConsult"
        class="h-9 w-auto"
      />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8">
      {site.nav.map(item => (
        <li>
          <a
            href={item.href}
            class="text-sm text-gray-300 hover:text-white transition-colors duration-200"
          >
            {item.label}
            <span class="block text-xs text-gray-500">{item.zhLabel}</span>
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a
      href={site.hero.cta.primary.href}
      class="hidden md:inline-flex btn-primary text-sm !py-2.5 !px-5"
    >
      WhatsApp
    </a>

    <!-- Mobile menu trigger (placeholder — can be enhanced with Alpine/JS) -->
    <button
      class="md:hidden text-white p-2"
      aria-label="Toggle menu"
      onclick="document.getElementById('mobile-menu')?.classList.toggle('hidden')"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden bg-black/95 border-t border-white/[0.06] px-6 py-4">
    <ul class="flex flex-col gap-4">
      {site.nav.map(item => (
        <li>
          <a
            href={item.href}
            class="block text-gray-300 hover:text-white py-1"
            onclick="document.getElementById('mobile-menu')?.classList.add('hidden')"
          >
            {item.label} <span class="text-gray-500 text-sm">— {item.zhLabel}</span>
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href={site.hero.cta.primary.href} class="btn-primary text-sm w-full justify-center">
          WhatsApp
        </a>
      </li>
    </ul>
  </div>
</header>
