---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const project = {
  name: 'HK Driving Exam App',
  icon: '🚗',
  tagline: 'Ace your Hong Kong driving license exam with AI-powered practice.',
  description: 'A comprehensive mobile app designed specifically for Hong Kong driving license candidates. Covers the full written test syllabus with mock exams, road sign recognition quizzes, and AI-powered mistake analysis that adapts to your weak spots.',
  features: [
    { icon: '📝', title: 'Full Mock Exams', desc: 'Realistic test simulations covering all HK Transport Department question banks — private car, motorcycle, taxi, and commercial vehicle.' },
    { icon: '🚦', title: 'Road Sign Trainer', desc: 'Interactive road sign quizzes with high-quality illustrations of every HK road sign category.' },
    { icon: '🤖', title: 'AI Mistake Analysis', desc: 'The app tracks your wrong answers and generates personalized review sessions targeting your weak areas.' },
    { icon: '📊', title: 'Progress Dashboard', desc: 'Visual stats showing your readiness score, time spent, and topics mastered — so you know exactly when you\'re exam-ready.' },
    { icon: '🌐', title: 'Bilingual (EN/中文)', desc: 'Full Chinese and English support, matching the actual exam format.' },
    { icon: '📱', title: 'Offline Mode', desc: 'Practice anywhere — on the MTR, in a queue, no connection needed.' },
  ],
  tech: ['React Native', 'Supabase', 'OpenAI API'],
  status: 'building',
};
---

<BaseLayout title={project.name} description={project.description}>
  <Header />
  <main class="pt-24 md:pt-32">
    <div class="section-container">
      <!-- Back -->
      <a href="/#projects" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors mb-12 text-sm">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to all projects
      </a>

      <!-- Hero -->
      <div class="max-w-3xl mb-20">
        <div class="flex items-center gap-4 mb-6">
          <span class="text-4xl">{project.icon}</span>
          <span class="flex items-center gap-1.5 text-sm text-amber-400 bg-amber-400/10 px-3 py-1.5 rounded-full">
            <span class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse" />
            In Development
          </span>
        </div>
        <h1 class="section-heading text-4xl md:text-5xl mb-6">{project.name}</h1>
        <p class="text-lg text-gray-400 leading-relaxed">{project.tagline}</p>
      </div>

      <!-- Description -->
      <div class="max-w-3xl mb-16">
        <p class="text-gray-300 leading-relaxed">{project.description}</p>
      </div>

      <!-- Features grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-16 max-w-5xl">
        {project.features.map(f => (
          <div class="card">
            <div class="text-2xl mb-3">{f.icon}</div>
            <h3 class="text-white font-heading font-bold text-sm mb-2">{f.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>

      <!-- Tech + CTA -->
      <div class="max-w-3xl">
        <div class="flex flex-wrap gap-2 mb-8">
          {project.tech.map(t => (
            <span class="text-sm text-gray-400 bg-white/[0.04] px-3 py-1.5 rounded-full border border-white/[0.06]">{t}</span>
          ))}
        </div>

        <div class="card flex flex-col sm:flex-row items-start sm:items-center gap-6">
          <div class="flex-1">
            <h3 class="font-heading font-bold text-lg mb-1">Want early access?</h3>
            <p class="text-gray-400 text-sm">We're looking for beta testers in Hong Kong. Get notified when the app launches.</p>
          </div>
          <a href="/#contact" class="btn-primary text-sm !py-3 !px-6 whitespace-nowrap">
            Join the waitlist
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
