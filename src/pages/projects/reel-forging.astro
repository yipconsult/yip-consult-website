---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const project = {
  name: 'ReelForge',
  icon: '🏠',
  tagline: 'Turn property listings into scroll-stopping short videos — automatically. Built for Hong Kong real estate agencies.',
  description: 'ReelForge transforms static property listings into engaging short-form video content for Instagram Reels, TikTok, and Facebook. Upload a listing — photos, floor plan, key details — and the AI generates a polished video with captions, transitions, pricing overlays, and voiceover in Cantonese or English, ready to publish in minutes.',
  features: [
    { icon: '🎬', title: 'One-Click Video Generation', desc: 'Drop in property photos and details — ReelForge auto-generates a complete video with pacing, transitions, and text overlays.' },
    { icon: '🗣️', title: 'AI Voiceover (Canto/EN)', desc: 'Auto-generated voiceovers in natural Cantonese or English describing the property highlights.' },
    { icon: '🏢', title: 'Branded Templates', desc: 'Upload your agency logo, colors, and contact info once — every video stays on-brand automatically.' },
    { icon: '📐', title: 'Floor Plan Animations', desc: 'Animated walkthroughs of floor plans with room labels and area highlights — no video editing skills needed.' },
    { icon: '📊', title: 'Batch Processing', desc: 'Process entire portfolios at once. 50 listings? 50 videos. Post-ready in under an hour.' },
    { icon: '📱', title: 'Multi-Platform Export', desc: 'Optimized aspect ratios for Instagram Reels (9:16), TikTok, Facebook, and YouTube Shorts in one click.' },
  ],
  tech: ['Next.js', 'FFmpeg', 'OpenAI API', 'ElevenLabs'],
  status: 'building',
};
---

<BaseLayout title={project.name} description={project.description}>
  <Header />
  <main class="pt-24 md:pt-32">
    <div class="section-container">
      <a href="/#projects" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors mb-12 text-sm">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to all projects
      </a>

      <div class="max-w-3xl mb-20">
        <div class="flex items-center gap-4 mb-6">
          <span class="text-4xl">{project.icon}</span>
          <span class="flex items-center gap-1.5 text-sm text-amber-400 bg-amber-400/10 px-3 py-1.5 rounded-full">
            <span class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse" />
            In Development
          </span>
        </div>
        <h1 class="section-heading text-4xl md:text-5xl mb-6">{project.name}</h1>
        <p class="text-lg text-gray-400 leading-relaxed">{project.tagline}</p>
      </div>

      <div class="max-w-3xl mb-16">
        <p class="text-gray-300 leading-relaxed">{project.description}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-16 max-w-5xl">
        {project.features.map(f => (
          <div class="card">
            <div class="text-2xl mb-3">{f.icon}</div>
            <h3 class="text-white font-heading font-bold text-sm mb-2">{f.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>

      <div class="max-w-3xl">
        <div class="flex flex-wrap gap-2 mb-8">
          {project.tech.map(t => (
            <span class="text-sm text-gray-400 bg-white/[0.04] px-3 py-1.5 rounded-full border border-white/[0.06]">{t}</span>
          ))}
        </div>

        <div class="card flex flex-col sm:flex-row items-start sm:items-center gap-6">
          <div class="flex-1">
            <h3 class="font-heading font-bold text-lg mb-1">Want this for your agency?</h3>
            <p class="text-gray-400 text-sm">We're piloting with select HK property agencies. Let us know your needs and get priority access at launch.</p>
          </div>
          <a href="/#contact" class="btn-primary text-sm !py-3 !px-6 whitespace-nowrap">
            Request early access
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
