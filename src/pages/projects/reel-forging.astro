---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import site from '../../data/site.json';

const project = site.projects.items.find(p => p.slug === 'reel-forging');
---

<BaseLayout title={project.name} description={project.description}>
  <Header />
  <main class="pt-24 md:pt-32">
    <div class="section-container">
      <a href="/#projects" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors mb-10 text-sm">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to all projects
      </a>

      <div class="max-w-3xl">
        <div class="flex items-center gap-4 mb-6">
          <span class="text-4xl">{project.icon}</span>
          <span class="flex items-center gap-1.5 text-sm text-amber-400 bg-amber-400/10 px-3 py-1.5 rounded-full">
            <span class="w-1.5 h-1.5 bg-amber-400 rounded-full" />
            In Development
          </span>
        </div>

        <h1 class="section-heading text-4xl md:text-5xl mb-6">{project.name}</h1>
        <p class="text-lg text-gray-400 leading-relaxed mb-8">{project.description}</p>

        <div class="flex flex-wrap gap-2 mb-12">
          {project.tech.map(t => (
            <span class="text-sm text-gray-400 bg-white/[0.04] px-3 py-1.5 rounded-full border border-white/[0.06]">{t}</span>
          ))}
        </div>

        <div class="card max-w-md">
          <h3 class="font-heading font-bold text-lg mb-2">Coming Soon</h3>
          <p class="text-gray-400 text-sm mb-4">We're actively building this project. Interested in early access or want to discuss something similar?</p>
          <a href="/#contact" class="btn-primary text-sm !py-2.5 !px-5">
            Get in touch
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
