---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const project = {
  name: 'CantoQuest',
  icon: '🗣️',
  tagline: 'Learn practical Cantonese through AI-powered conversations — designed for Mandarin speakers relocating to Hong Kong.',
  description: 'CantoQuest bridges the language gap for mainland professionals and families moving to Hong Kong. Instead of textbook drills, you learn through realistic daily scenarios — ordering at cha chaan teng, talking to taxi drivers, negotiating at wet markets — with instant AI pronunciation feedback.',
  features: [
    { icon: '🎙️', title: 'AI Pronunciation Coach', desc: 'Speak into the app and get real-time feedback on your tones and pronunciation using Whisper AI speech recognition.' },
    { icon: '🏪', title: 'Real-Life Scenarios', desc: 'Practice conversations you\'ll actually have: ordering food, visiting the bank, parent-teacher meetings, and navigating HK transport.' },
    { icon: '📖', title: 'Jyutping + Characters', desc: 'Learn both romanized Cantonese (Jyutping) and traditional Chinese characters side by side.' },
    { icon: '🔄', title: 'Mandarin Bridge Mode', desc: 'Leverage your existing Mandarin knowledge — the app highlights Cantonese-Mandarin differences and shared vocabulary.' },
    { icon: '🏆', title: 'Gamified Progress', desc: 'Unlock badges, track daily streaks, and compete on leaderboards with other learners in Hong Kong.' },
    { icon: '📱', title: 'WhatsApp Integration', desc: 'Optional daily micro-lessons delivered via WhatsApp — learn 5 minutes a day without opening another app.' },
  ],
  tech: ['Next.js', 'Whisper API', 'Supabase', 'WhatsApp API'],
  status: 'building',
};
---

<BaseLayout title={project.name} description={project.description}>
  <Header />
  <main class="pt-24 md:pt-32">
    <div class="section-container">
      <a href="/#projects" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors mb-12 text-sm">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to all projects
      </a>

      <div class="max-w-3xl mb-20">
        <div class="flex items-center gap-4 mb-6">
          <span class="text-4xl">{project.icon}</span>
          <span class="flex items-center gap-1.5 text-sm text-amber-400 bg-amber-400/10 px-3 py-1.5 rounded-full">
            <span class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse" />
            In Development
          </span>
        </div>
        <h1 class="section-heading text-4xl md:text-5xl mb-6">{project.name}</h1>
        <p class="text-lg text-gray-400 leading-relaxed">{project.tagline}</p>
      </div>

      <div class="max-w-3xl mb-16">
        <p class="text-gray-300 leading-relaxed">{project.description}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-16 max-w-5xl">
        {project.features.map(f => (
          <div class="card">
            <div class="text-2xl mb-3">{f.icon}</div>
            <h3 class="text-white font-heading font-bold text-sm mb-2">{f.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>

      <div class="max-w-3xl">
        <div class="flex flex-wrap gap-2 mb-8">
          {project.tech.map(t => (
            <span class="text-sm text-gray-400 bg-white/[0.04] px-3 py-1.5 rounded-full border border-white/[0.06]">{t}</span>
          ))}
        </div>

        <div class="card flex flex-col sm:flex-row items-start sm:items-center gap-6">
          <div class="flex-1">
            <h3 class="font-heading font-bold text-lg mb-1">Interested in early access?</h3>
            <p class="text-gray-400 text-sm">We're building this for the HK newcomer community. Tell us what you need most in a Cantonese learning app.</p>
          </div>
          <a href="/#contact" class="btn-primary text-sm !py-3 !px-6 whitespace-nowrap">
            Get in touch
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
