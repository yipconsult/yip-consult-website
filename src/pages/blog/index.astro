---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Blog" description="Insights on AI automation, web development, and digital transformation for Hong Kong SMEs.">
  <Header />
  <main class="pt-24 md:pt-32">
    <div class="section-container">
      <!-- Header -->
      <div class="mb-16">
        <span class="text-navy-light text-sm font-medium tracking-widest uppercase mb-4 block">Blog</span>
        <h1 class="section-heading mb-4">Insights</h1>
        <p class="section-subheading">AI 自動化、網頁開發、數碼轉型 — 為香港中小企而寫。</p>
      </div>

      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-gray-500 text-lg">No posts yet. Check back soon.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl">
          {posts.map(post => (
            <a
              href={`/blog/${post.slug}`}
              class="card group flex flex-col"
            >
              <!-- Date -->
              <time class="text-xs text-gray-500 mb-3">
                {post.data.date.toLocaleDateString('zh-HK', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>

              <!-- Title -->
              <h2 class="text-lg font-heading font-bold tracking-snug mb-2
                         group-hover:text-navy-light transition-colors duration-300">
                {post.data.title}
              </h2>

              <!-- Description -->
              <p class="text-sm text-gray-400 leading-relaxed mb-5 flex-1">
                {post.data.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mb-4">
                {post.data.tags.map(tag => (
                  <span class="text-xs text-gray-500 bg-white/[0.04] px-2 py-0.5 rounded-full border border-white/[0.06]">
                    #{tag}
                  </span>
                ))}
              </div>

              <!-- Read more -->
              <span class="text-sm text-navy-light group-hover:underline underline-offset-4">
                Read more →
              </span>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
